{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "EcoDrive: MCU Release",
            "type": "shell",
            "command": "cd EcoDrive/build  && cmake .. -DCMAKE_BUILD_TYPE=Release -DPLATFORM_NAME=stm32f4 && make -j4",
            "group": "build",
            "problemMatcher": ["$gcc"] 
        },
        {
            "label": "EcoDrive: MCU Debug",
            "type": "shell",
            "command": "cd EcoDrive/build  && cmake .. -DCMAKE_BUILD_TYPE=Debug -DPLATFORM_NAME=stm32f4 && make -j4",
            "group": "build",
            "problemMatcher": ["$gcc"] 
        },
        {   
            "label": "EcoDrive: Clean",
            "type": "shell", 
            "command": "cd EcoDrive/build  && rm -rf *",
            "group": "build",
            "problemMatcher": ["$gcc"] 
        },
        {
            "label": "EcoDrive: Host Debug",
            "type": "shell",
            "command": "cd EcoDrive/build  && cmake .. -DCMAKE_BUILD_TYPE=Debug -DPLATFORM_NAME=host && make -j4",
            "group": "build",
            "problemMatcher": ["$gcc"] 
        },
       // EcoTool
        {
            "label": "EcoTool: Debug",
            "type": "shell",
            "command": "cd EcoTool/build && cmake .. -DCMAKE_BUILD_TYPE=Debug && make -j4",
            "group": "build",
            "problemMatcher": ["$gcc"] 
        },
        {
            "label": "EcoTool: Release",
            "type": "shell",
            "command": "cd EcoTool/build && cmake .. -DCMAKE_BUILD_TYPE=Release && make -j4",
            "group": "build",
            "problemMatcher": ["$gcc"] 
        },
        {
            "label": "EcoTool: Clean",
            "type": "shell",
            "command": "cd EcoTool/build && rm -rf *",
            "problemMatcher": ["$gcc"] 
        },
        {
            "label": "Test: Debug",
            "type": "shell",
            "command": "cd test/build && cmake .. -DCMAKE_BUILD_TYPE=Debug && make -j4",
            "problemMatcher": ["$gcc"] 
        },
                {
            "label": "Test: Clean",
            "type": "shell",
            "command": "cd test/build && rm -rf *",
            "problemMatcher": ["$gcc"] 
        },
        {
            "label": "Virtual PORTS",
            "type": "shell",
            "command": "sudo socat -d -d pty,link=/dev/ttyACM_CDC0,raw,echo=0,mode=666 pty,link=/dev/ttyACM_CDC1,raw,echo=0,mode=666",
            "isBackground": true
        },
    ]
}