{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Launch EcoDrive",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceRoot}/build/bin/EcoDrive",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(gdb) Launch sil_test",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceRoot}/build/bin/test_sil",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(gdb) Launch EcoTool",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceRoot}/EcoTool/EcoTool",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceRoot}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },

          {
            "name": "BMP launch",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceRoot}/build/bin/EcoDrive.elf",
            "armToolchainPath": "/usr/bin",
            "gdbPath": "/opt/gcc-arm-none-eabi-10.3/bin/arm-none-eabi-gdb",
            "BMPGDBSerialPort": "/dev/ttyBmpGdb",
            "showDevDebugOutput": "raw",
            "request": "launch",    // "launch" also works perhaps
            "type": "cortex-debug",
            "servertype": "bmp",
            "interface": "swd",
            "device": "STM32FF401"
        }
    ]
}
