)

target_include_directories(host_platform PUBLIC ${HOST_COMMON_INCLUDES})
target_compile_definitions(host_platform PUBLIC
    ${DEVICE_DEFINITIONS}
    projCOVERAGE_TEST=0
    projENABLE_TRACING=0
)

